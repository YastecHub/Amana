generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Cooperative {
  id                 String   @id @map("_id") @default(auto()) @db.ObjectId
  name               String
  adminUserId        String   @db.ObjectId
  contributionAmount Float    @default(5000)
  cycle              String   @default("monthly")
  maxLoanMultiple    Int      @default(3)
  createdAt          DateTime @default(now())
  adminUser          User     @relation(fields: [adminUserId], references: [id])
  members            Member[]
}

model User {
  id           String        @id @map("_id") @default(auto()) @db.ObjectId
  role         String
  name         String
  phone        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  cooperatives Cooperative[]
  member       Member?
}

model Member {
  id            String          @id @map("_id") @default(auto()) @db.ObjectId
  cooperativeId String          @db.ObjectId
  userId        String          @unique @db.ObjectId
  bvnStatus     String          @default("pending")
  joinDate      DateTime        @default(now())
  status        String          @default("active")
  cooperative   Cooperative     @relation(fields: [cooperativeId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  virtualAccount VirtualAccount?
  contributions  Contribution[]
  loans          Loan[]
  scores         Score[]
}

model VirtualAccount {
  id                      String   @id @map("_id") @default(auto()) @db.ObjectId
  memberId                String   @unique @db.ObjectId
  monnifyAccountReference String   @unique
  accountNumber           String
  bankName                String
  bankCode                String   @default("000")
  createdAt               DateTime @default(now())
  member                  Member   @relation(fields: [memberId], references: [id])
}

model Contribution {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  memberId      String   @db.ObjectId
  amount        Float
  paidAt        DateTime @default(now())
  monnifyTxnRef String   @unique
  narration     String   @default("")
  status        String   @default("confirmed")
  member        Member   @relation(fields: [memberId], references: [id])
}

model Loan {
  id              String      @id @map("_id") @default(auto()) @db.ObjectId
  memberId        String      @db.ObjectId
  principal       Float
  status          String      @default("requested")
  scoreAtDecision Float?
  breakdownJson   String      @default("{}")
  disbursementRef String?     @unique
  aiExplanation   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  member          Member      @relation(fields: [memberId], references: [id])
  repayments      Repayment[]
}

model Repayment {
  id     String    @id @map("_id") @default(auto()) @db.ObjectId
  loanId String    @db.ObjectId
  amount Float
  dueDate DateTime?
  paidAt  DateTime?
  status  String    @default("pending")
  loan    Loan      @relation(fields: [loanId], references: [id])
}

model Score {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  memberId      String   @db.ObjectId
  value         Float
  band          String
  breakdownJson String   @default("{}")
  label         String   @default("")
  computedAt    DateTime @default(now())
  member        Member   @relation(fields: [memberId], references: [id])
}

model WebhookLog {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  monnifyRef  String   @unique
  eventType   String
  payloadJson String
  processedAt DateTime @default(now())
}
